<Window x:Class="FacturacionA4V.UI.Views.AgregarPagoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar pago"
        Width="320"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Este pago se adjuntará a los registros seleccionados"
                   FontWeight="SemiBold"/>

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Fecha de pago"/>
            <DatePicker SelectedDate="{Binding FechaPago}"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancelar"
                    Width="90"
                    Margin="0,0,8,0"
                    IsCancel="True"/>

            <Button Content="Pagar"
                    Width="90"
                    IsDefault="True"
                    IsEnabled="{Binding IsValid}"
                    Click="OnAceptar"/>
        </StackPanel>
    </Grid>
</Window>
