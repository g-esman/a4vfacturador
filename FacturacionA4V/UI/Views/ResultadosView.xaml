<UserControl x:Class="FacturacionA4V.UI.Views.ResultadosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <!-- =========================
         RECURSOS
    ========================== -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="SinFacturaBrush" Color="#FFE0E0E0"/>
        <SolidColorBrush x:Key="PagadaBrush" Color="#FFB6E3B6"/>
        <SolidColorBrush x:Key="Menor30Brush" Color="#FFB3D9FF"/>
        <SolidColorBrush x:Key="Dias30Brush" Color="#FFFFF0B3"/>
        <SolidColorBrush x:Key="Dias60Brush" Color="#FFFFD699"/>
        <SolidColorBrush x:Key="Dias90Brush" Color="#FFFFB3B3"/>
    </UserControl.Resources>

    <!-- =========================
         LAYOUT PRINCIPAL
    ========================== -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- filtros -->
            <RowDefinition Height="*"/>
            <!-- grilla -->
            <RowDefinition Height="Auto"/>
            <!-- acciones + totales -->
        </Grid.RowDefinitions>

        <!-- =========================
             FILTROS
        ========================== -->
        <Border Grid.Row="0"
                Padding="8"
                Margin="0,0,0,8"
                Background="#F5F5F5"
                CornerRadius="4">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Auspiciante" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding AuspiciantesDisponibles}"
                              SelectedItem="{Binding AuspicianteSeleccionado}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              Height="28"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="Programa" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding ProgramasDisponibles}"
                              SelectedItem="{Binding ProgramaSeleccionado}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              Height="28"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <TextBlock Text="Periodista" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding PeriodistasDisponibles}"
                              SelectedItem="{Binding PeriodistaSeleccionado}"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              Height="28"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="8,0,0,0">
                    <TextBlock Text="Año" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding AniosDisponibles}"
                              SelectedItem="{Binding AnioSeleccionado}"
                              Height="28"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Margin="8,0,0,0">
                    <TextBlock Text="Mes" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <ComboBox ItemsSource="{Binding MesesDisponibles}"
                              SelectedItem="{Binding MesSeleccionado}"
                              DisplayMemberPath="Nombre"
                              Height="28"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Margin="8,0,0,0">
                    <Button Content="Limpiar"
                            Command="{Binding LimpiarFiltrosCommand}"
                            Margin="4,18,0,0"
                            Padding="12,6"/>
                </StackPanel>

                <!-- FILA 2: Filtros por fecha de pago -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <TextBlock Text="Fecha pago desde" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <DatePicker SelectedDate="{Binding FechaPagoDesde}"
                                Height="28"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,8,0,0">
                    <TextBlock Text="Fecha pago hasta" FontSize="{StaticResource FontSizeSmall}" Opacity="0.7"/>
                    <DatePicker SelectedDate="{Binding FechaPagoHasta}"
                                Height="28"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- =========================
             GRILLA
        ========================== -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Filtrados}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  RowHeight="26">

            <!-- SEMÁFORO -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow"
                       BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background" Value="{StaticResource SinFacturaBrush}"/>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Estado}" Value="Pagada">
                            <Setter Property="Background" Value="{StaticResource PagadaBrush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="FacturadaMenor30">
                            <Setter Property="Background" Value="{StaticResource Menor30Brush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="Facturada30">
                            <Setter Property="Background" Value="{StaticResource Dias30Brush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="Facturada60">
                            <Setter Property="Background" Value="{StaticResource Dias60Brush}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Estado}" Value="Facturada90">
                            <Setter Property="Background" Value="{StaticResource Dias90Brush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <!-- COLUMNAS -->
            <DataGrid.Columns>

                <!-- SELECCIÓN -->
                <DataGridTemplateColumn Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected,
                                         Mode=TwoWay,
                                         UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Auspiciante" Binding="{Binding Auspiciante}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Programa" Binding="{Binding Programa}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Periodista" Binding="{Binding Periodista}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Monto" Binding="{Binding MontoTexto}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Mes/Año" Binding="{Binding MesAnio}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Información Adicional" Binding="{Binding InformacionAdicional}" IsReadOnly="True"/>
                <DataGridTextColumn Header="N° Factura" Binding="{Binding NroFactura}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Fecha Factura"
                                    Binding="{Binding FechaFactura}"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="Nota Factura" Binding="{Binding Nota}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Fecha Pago"
                                    Binding="{Binding FechaPago}"
                                    IsReadOnly="True"/>

            </DataGrid.Columns>
        </DataGrid>

        <!-- =========================
             ACCIONES + TOTALES
        ========================== -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ACCIONES -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Agregar factura"
                        Command="{Binding AgregarFacturaCommand}"
                        Padding="12,6"/>
                <Button Content="Agregar pago"
                        Command="{Binding AgregarPagoCommand}"
                        Margin="8,0,0,0"
                        Padding="12,6"/>
                <Button Content="Agregar información adicional"
                        Command="{Binding AgregarInfoAdicionalCommand}"
                        Margin="8,0,0,0"
                        Padding="12,6"/>
            </StackPanel>

            <!-- TOTALES -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding TotalFacturado, StringFormat=Total: {0:C}}"/>
                <TextBlock Margin="16,0,0,0"
                           Text="{Binding TotalCobrado, StringFormat=Cobrado: {0:C}}"/>
                <TextBlock Margin="16,0,0,0"
                           Text="{Binding TotalPendiente, StringFormat=Pendiente: {0:C}}"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
