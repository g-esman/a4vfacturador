<UserControl x:Class="FacturacionA4V.UI.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="480" HorizontalAlignment="Left">

            <!-- TÍTULO -->
            <TextBlock Text="Configuración"
                       FontSize="{DynamicResource FontSizeLarge}"
                       FontWeight="Bold"
                       Margin="0,0,0,24"/>

            <!-- SECCIÓN: Tipografía -->
            <TextBlock Text="TIPOGRAFÍA"
                       FontSize="{DynamicResource FontSizeSmall}"
                       Foreground="{DynamicResource AppForegroundMutedBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="6" Padding="16" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Tamaño de texto" Margin="0,0,0,4"/>
                    <DockPanel>
                        <TextBlock Text="{Binding FontSizeBase, StringFormat={}{0:0}px}"
                                   DockPanel.Dock="Right" Width="36" TextAlignment="Right"
                                   Foreground="{DynamicResource AppForegroundMutedBrush}"/>
                        <Slider Value="{Binding FontSizeBase}" Minimum="10" Maximum="22" TickFrequency="1" IsSnapToTickEnabled="True"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- SECCIÓN: Tema -->
            <TextBlock Text="TEMA"
                       FontSize="{DynamicResource FontSizeSmall}"
                       Foreground="{DynamicResource AppForegroundMutedBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="6" Padding="16" Margin="0,0,0,32">
                <CheckBox Content="Modo oscuro"
                          IsChecked="{Binding DarkMode}"/>
            </Border>

            <!-- SECCIÓN: Vista previa -->
            <TextBlock Text="VISTA PREVIA"
                       FontSize="{DynamicResource FontSizeSmall}"
                       Foreground="{DynamicResource AppForegroundMutedBrush}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="6" Padding="16" Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold"
                               Text="Título de pantalla (Grande)"/>
                    <TextBlock FontSize="{DynamicResource FontSizeMedium}"
                               Margin="0,8,0,0"
                               Text="Encabezado de columna (Medio)"/>
                    <TextBlock FontSize="{DynamicResource FontSizeBase}"
                               Margin="0,8,0,0"
                               Text="Texto general del cuerpo (Base)"/>
                    <TextBlock FontSize="{DynamicResource FontSizeSmall}"
                               Foreground="{DynamicResource AppForegroundMutedBrush}"
                               Margin="0,8,0,0"
                               Text="Label o hint pequeño (Pequeño)"/>
                </StackPanel>
            </Border>

            <!-- ACCIONES -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Guardar"
                        Command="{Binding GuardarCommand}"
                        Padding="20,8"/>
                <Button Content="Restaurar valores por defecto"
                        Command="{Binding RestaurarCommand}"
                        Margin="12,0,0,0"
                        Padding="20,8"/>
                <TextBlock Text="✓ Configuración guardada"
                           Foreground="#4CAF50"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Visibility="{Binding IsGuardado, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <TextBlock Text="Los cambios se aplican en tiempo real. Guardar los persiste para la próxima vez."
                       Foreground="{DynamicResource AppForegroundMutedBrush}"
                       FontSize="{DynamicResource FontSizeSmall}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
