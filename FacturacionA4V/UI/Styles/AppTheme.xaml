<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- =====================================================
         TAMAÑOS DE FUENTE — modificar solo aquí
         ===================================================== -->
    <sys:Double x:Key="FontSizeSmall">12</sys:Double>
    <sys:Double x:Key="FontSizeBase">14</sys:Double>
    <sys:Double x:Key="FontSizeMedium">15</sys:Double>
    <sys:Double x:Key="FontSizeLarge">16</sys:Double>

    <!-- =====================================================
         COLORES ESTRUCTURALES — valores por defecto (modo claro)
         ThemeService los sobreescribe en runtime
         ===================================================== -->
    <SolidColorBrush x:Key="AppBackgroundBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSurfaceBrush"         Color="#F5F5F5"/>
    <SolidColorBrush x:Key="AppSurfaceAltBrush"      Color="#EBEBEB"/>
    <SolidColorBrush x:Key="AppForegroundBrush"      Color="#1A1A1A"/>
    <SolidColorBrush x:Key="AppForegroundMutedBrush" Color="#666666"/>
    <SolidColorBrush x:Key="AppBorderBrush"          Color="#DDDDDD"/>
    <SolidColorBrush x:Key="AppInputBgBrush"         Color="#FFFFFF"/>

    <!-- Botón -->
    <SolidColorBrush x:Key="AppButtonBgBrush"    Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AppButtonFgBrush"    Color="#1A1A1A"/>
    <SolidColorBrush x:Key="AppButtonHoverBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="AppButtonPressBrush" Color="#B8B8B8"/>

    <!-- =====================================================
         WINDOW
         ===================================================== -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
    </Style>

    <!-- =====================================================
         TEXTOS
         ===================================================== -->
    <Style TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
    </Style>

    <!-- =====================================================
         TEXTBOX
         ===================================================== -->
    <Style TargetType="TextBox">
        <Setter Property="FontSize"       Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Background"     Value="{DynamicResource AppInputBgBrush}"/>
        <Setter Property="Foreground"     Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush"    Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="CaretBrush"     Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AppButtonHoverBrush}"/>
        <Setter Property="Padding"        Value="4,2"/>
    </Style>

    <!-- DatePickerTextBox: input interno del DatePicker -->
    <Style TargetType="{x:Type DatePickerTextBox}">
        <Setter Property="Background"     Value="{DynamicResource AppInputBgBrush}"/>
        <Setter Property="Foreground"     Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="CaretBrush"     Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AppButtonHoverBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize"       Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- =====================================================
         COMBOBOX — template propio para que el valor seleccionado
         use nuestros colores, no los del sistema
         ===================================================== -->
    <Style TargetType="ComboBox">
        <Setter Property="FontSize"       Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Background"     Value="{DynamicResource AppInputBgBrush}"/>
        <Setter Property="Foreground"     Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush"    Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"        Value="4,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="Root">

                        <!-- Fondo y borde del control -->
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"/>

                        <!-- Botón invisible que cubre todo para capturar clicks y abrir el dropdown -->
                        <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                 RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <!-- Valor seleccionado (modo no editable) -->
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="6,0,24,0"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"/>

                        <!-- Input editable (modo editable) -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Background="Transparent"
                                 Foreground="{TemplateBinding Foreground}"
                                 CaretBrush="{TemplateBinding Foreground}"
                                 SelectionBrush="{DynamicResource AppButtonHoverBrush}"
                                 FontSize="{TemplateBinding FontSize}"
                                 Margin="4,0,24,0"
                                 VerticalAlignment="Center"
                                 BorderThickness="0"
                                 Padding="0"
                                 Visibility="Hidden"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>

                        <!-- Flecha -->
                        <Path x:Name="Arrow"
                              Data="M 0 0 L 4 4 L 8 0"
                              Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.5"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              IsHitTestVisible="False"/>

                        <!-- Popup con los items -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDown"
                                    Background="{DynamicResource AppInputBgBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    MinWidth="{Binding ActualWidth,
                                               RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Modo editable: ocultar ContentPresenter, mostrar TextBox -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="ContentSite"        Property="Visibility" Value="Hidden"/>
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush"
                                    Value="{DynamicResource AppForegroundMutedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource AppInputBgBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="Padding"    Value="6,3"/>
        <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =====================================================
         DATEPICKER + CALENDAR
         Estrategia: CalendarStyle con Template propio del Calendar.
         Dentro del ControlTemplate.Resources definimos los estilos
         implícitos para Day/CalendarButton, y referenciamos CalendarItem
         por key explícito para saltear el StaticResource del tema Aero2.
         ===================================================== -->
    <Style TargetType="DatePicker">
        <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Background"      Value="{DynamicResource AppInputBgBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CalendarStyle">
            <Setter.Value>
                <Style TargetType="Calendar">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Calendar">
                                <ControlTemplate.Resources>

                                    <!-- CalendarItem con key explícito para bypasear el StaticResource del tema.
                                         CalendarDayButton/CalendarButton/DayTitleTemplate van en los
                                         ControlTemplate.Resources del CalendarItem (donde PopulateGrids los necesita). -->
                                    <Style x:Key="AppCalendarItemStyle" TargetType="CalendarItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CalendarItem">
                                                    <ControlTemplate.Resources>

                                                        <!-- Header de días de la semana -->
                                                        <DataTemplate x:Key="DayTitleTemplate">
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="{DynamicResource FontSizeSmall}"
                                                                       Foreground="{DynamicResource AppForegroundMutedBrush}"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,2,0,4"/>
                                                        </DataTemplate>

                                                        <!-- Botón de día — PopulateGrids crea CalendarDayButton sin Style explícito,
                                                             el lookup los encuentra en este scope -->
                                                        <Style TargetType="CalendarDayButton">
                                                            <Setter Property="MinWidth"  Value="32"/>
                                                            <Setter Property="MinHeight" Value="26"/>
                                                            <Setter Property="FontSize"  Value="{DynamicResource FontSizeBase}"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                            <Setter Property="VerticalContentAlignment"   Value="Center"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="CalendarDayButton">
                                                                        <Grid>
                                                                            <Border x:Name="Bg" Background="Transparent" CornerRadius="2" Margin="1"/>
                                                                            <Border x:Name="TodayBorder"
                                                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                                                    BorderThickness="1" CornerRadius="2" Margin="1"
                                                                                    Visibility="Collapsed"/>
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                              TextBlock.Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                        </Grid>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsToday" Value="True">
                                                                                <Setter TargetName="TodayBorder" Property="Visibility" Value="Visible"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppButtonBgBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.35"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>

                                                        <!-- Botón de mes/año -->
                                                        <Style TargetType="CalendarButton">
                                                            <Setter Property="MinWidth"  Value="52"/>
                                                            <Setter Property="MinHeight" Value="40"/>
                                                            <Setter Property="FontSize"  Value="{DynamicResource FontSizeBase}"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                            <Setter Property="VerticalContentAlignment"   Value="Center"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="CalendarButton">
                                                                        <Grid>
                                                                            <Border x:Name="Bg" Background="Transparent" CornerRadius="2" Margin="1"/>
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                              TextBlock.Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                        </Grid>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AppSurfaceAltBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.35"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>

                                                    </ControlTemplate.Resources>

                                                    <Grid x:Name="PART_Root">
                                                        <Border Background="{DynamicResource AppSurfaceBrush}"
                                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                                BorderThickness="1"
                                                                Padding="8,6">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="28"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="28"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Button x:Name="PART_PreviousButton"
                                                                            Content="◀" FontSize="9"
                                                                            Height="24" Width="24"
                                                                            Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                    <Button x:Name="PART_HeaderButton"
                                                                            Grid.Column="1"
                                                                            HorizontalAlignment="Center"
                                                                            FontWeight="SemiBold" Height="24"
                                                                            Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                    <Button x:Name="PART_NextButton"
                                                                            Grid.Column="2"
                                                                            Content="▶" FontSize="9"
                                                                            Height="24" Width="24"
                                                                            Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                </Grid>
                                                                <Grid x:Name="PART_MonthView" Grid.Row="1" Margin="0,4,0,0"/>
                                                                <Grid x:Name="PART_YearView"  Grid.Row="1" Margin="0,4,0,0" Visibility="Hidden"/>
                                                            </Grid>
                                                        </Border>
                                                        <Rectangle x:Name="PART_DisabledVisual"
                                                                   Fill="{DynamicResource AppSurfaceBrush}"
                                                                   Opacity="0.6" IsHitTestVisible="False"
                                                                   Visibility="Collapsed"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="PART_DisabledVisual" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>

                                </ControlTemplate.Resources>

                                <CalendarItem x:Name="PART_CalendarItem"
                                              Style="{StaticResource AppCalendarItemStyle}"/>

                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =====================================================
         BOTÓN
         ===================================================== -->
    <Style TargetType="Button">
        <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Background"      Value="{DynamicResource AppButtonBgBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource AppButtonFgBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AppButtonPressBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToggleButton (selector de meses) -->
    <Style TargetType="ToggleButton">
        <Setter Property="FontSize"        Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Background"      Value="{DynamicResource AppButtonBgBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource AppButtonFgBrush}"/>
        <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="4,2"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AppButtonPressBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AppForegroundMutedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="FontSize"   Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
    </Style>

    <!-- Slider -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
    </Style>

    <!-- =====================================================
         DATAGRID
         Los fondos de fila son siempre colores semáforo claros,
         por eso el texto de las celdas es siempre oscuro fijo.
         Los encabezados sí usan DynamicResource (cambian con el tema).
         ===================================================== -->
    <Style TargetType="DataGrid">
        <Setter Property="FontSize"                 Value="{DynamicResource FontSizeBase}"/>
        <Setter Property="Background"               Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="Foreground"               Value="#1A1A1A"/>
        <Setter Property="RowBackground"            Value="{DynamicResource AppBackgroundBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="BorderBrush"              Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="{DynamicResource AppBorderBrush}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="FontSize"    Value="{DynamicResource FontSizeMedium}"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Background"  Value="{DynamicResource AppSurfaceAltBrush}"/>
        <Setter Property="Foreground"  Value="{DynamicResource AppForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="Padding"     Value="8,4"/>
    </Style>

    <!-- Texto de filas y celdas siempre oscuro (fondos semáforo son siempre claros) -->
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="#1A1A1A"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="Foreground"  Value="#1A1A1A"/>
    </Style>

    <!-- ScrollViewer -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
    </Style>

</ResourceDictionary>
