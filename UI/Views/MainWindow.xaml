<Window x:Class="FacturacionA4V.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FacturacionA4V.UI.Views"
        Title="Facturación" Width="1200" Height="700"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra superior -->
        <Border Background="#F5F5F5" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Carga"
                        Click="OnCargaClick"
                        Padding="12,6"/>

                <Button Content="Resultados"
                        Click="OnResultadosClick"
                        Margin="8,0,0,0"
                        Padding="12,6"/>
            </StackPanel>
        </Border>

        <!-- Contenido -->
        <ContentControl x:Name="ShellContent"
                        Grid.Row="1"/>
    </Grid>
</Window>
